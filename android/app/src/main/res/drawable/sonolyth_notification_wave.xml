<?xml version="1.0" encoding="utf-8"?>
<!-- Status-bar / media-notification small icon: five rounded sound-wave bars
     in an asymmetric waveform (matches the launcher mark). Android renders
     small icons as a pure-white alpha mask, so this stays a plain silhouette.
     Resolved by NAME via audio_service (getResourceId) - it must be listed
     in res/raw/keep.xml or R8 strips it from releases. -->

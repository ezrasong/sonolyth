<?xml version="1.0" encoding="utf-8"?>
<!-- Status-bar / media-notification small icon: the Sonolyth monolith
     radiating sound waves, as a pure-white silhouette (Android renders
     small icons as an alpha mask). Resolved by NAME via audio_service
     (getResourceId) - it must be listed in res/raw/keep.xml or R8 strips
     it from releases. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
  <!-- monolith slab -->
  <path
      android:fillColor="#FFFFFFFF"
      android:pathData="M8,4.5 H9 C10.1,4.5 11,5.4 11,6.5 V17.5 C11,18.6 10.1,19.5 9,19.5 H8 C6.9,19.5 6,18.6 6,17.5 V6.5 C6,5.4 6.9,4.5 8,4.5 Z" />
  <!-- sound waves radiating right -->
  <path
      android:pathData="M14.06,9.46 A4,4 0 0 1 14.06,14.54"
      android:strokeColor="#FFFFFFFF"
      android:strokeWidth="2.2"
      android:strokeLineCap="round" />
  <path
      android:pathData="M17.13,6.93 A7.9,7.9 0 0 1 17.13,17.07"
      android:strokeColor="#FFFFFFFF"
      android:strokeWidth="2.2"
      android:strokeLineCap="round" />
</vector>

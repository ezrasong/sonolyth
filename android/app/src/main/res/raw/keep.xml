<?xml version="1.0" encoding="utf-8"?>
<!-- The media-notification button icons are resolved at runtime by name
     (Resources.getIdentifier in audio_service), which the release resource
     shrinker cannot trace. Without this keep rule they get stripped: the
     custom shuffle/repeat icons make every PlaybackState update throw "You
     must specify an icon resource id to build a CustomAction" (no media
     notification at all), and the stock audio_service transport icons leave
     the prev/play/next notification actions icon-less on OEM SystemUIs that
     render the notification's own buttons. -->
<resources xmlns:tools="http://schemas.android.com/tools"
    tools:keep="@drawable/sonolyth_shuffle,@drawable/sonolyth_shuffle_on,@drawable/sonolyth_shuffle_smart_on,@drawable/sonolyth_repeat,@drawable/sonolyth_repeat_on,@drawable/sonolyth_repeat_one_on,@drawable/sonolyth_notification_wave,@drawable/audio_service_play_arrow,@drawable/audio_service_pause,@drawable/audio_service_skip_next,@drawable/audio_service_skip_previous" />

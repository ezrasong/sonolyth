<?xml version="1.0" encoding="utf-8"?>
<!-- The media-notification shuffle/repeat button icons are resolved at
     runtime by name (Resources.getIdentifier in audio_service), which the
     release resource shrinker cannot trace. Without this keep rule they get
     stripped, every PlaybackState update throws "You must specify an icon
     resource id to build a CustomAction", and release builds end up with no
     media notification at all. -->
<resources xmlns:tools="http://schemas.android.com/tools"
    tools:keep="@drawable/sonolyth_shuffle,@drawable/sonolyth_shuffle_on,@drawable/sonolyth_repeat,@drawable/sonolyth_repeat_on,@drawable/sonolyth_repeat_one_on" />
